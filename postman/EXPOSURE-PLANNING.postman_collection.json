{
	"info": {
		"_postman_id": "exposure-planning-module-id",
		"name": "EXPOSURE-PLANNING",
		"description": "API collection for the EMDR Exposure Planning Module. Includes behavior selection, plan creation, and progress tracking.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Get Available Behaviors",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/exposure/behaviors",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"exposure",
						"behaviors"
					]
				},
				"description": "Returns the list of behaviors pre-defined for exposure therapy."
			},
			"response": []
		},
		{
			"name": "2. Create Exposure Plan",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"selectedBehavior\": \"Avoiding social situations\",\n  \"hierarchy\": [\n    { \"step\": \"Buying something from a local shop\", \"suds\": 2 },\n    { \"step\": \"Saying hello to a neighbor\", \"suds\": 4 },\n    { \"step\": \"Attending a small gathering with friends\", \"suds\": 6 },\n    { \"step\": \"Speaking up in an office meeting\", \"suds\": 8 },\n    { \"step\": \"Giving a presentation in front of 10 people\", \"suds\": 10 }\n  ]\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/exposure/plan",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"exposure",
						"plan"
					]
				},
				"description": "Creates a new exposure plan with a hierarchy of steps."
			},
			"response": []
		},
		{
			"name": "3. Get User Plans",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/exposure/plans",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"exposure",
						"plans"
					]
				},
				"description": "Retrieves all exposure plans for the logged-in user."
			},
			"response": []
		},
		{
			"name": "4. Get Plan Details",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/exposure/plan/:id",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"exposure",
						"plan",
						":id"
					],
					"variable": [
						{
							"key": "id",
							"value": "PLAN_ID_HERE"
						}
					]
				},
				"description": "Retrieves the full details of a specific exposure plan."
			},
			"response": []
		},
		{
			"name": "5. Update Step Completion",
			"request": {
				"method": "PATCH",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"stepIndex\": 0,\n  \"completed\": true\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/exposure/plan/:id/step",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"exposure",
						"plan",
						":id",
						"step"
					],
					"variable": [
						{
							"key": "id",
							"value": "PLAN_ID_HERE"
						}
					]
				},
				"description": "Marks a specific step in the hierarchy as completed or incomplete."
			},
			"response": []
		},
		{
			"name": "6. Get Plan Progress Summary",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/exposure/plan/:id/progress",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"exposure",
						"plan",
						":id",
						"progress"
					],
					"variable": [
						{
							"key": "id",
							"value": "PLAN_ID_HERE"
						}
					]
				},
				"description": "Retrieves a summary of the progress for a specific plan."
			},
			"response": []
		},
		{
			"name": "7. Delete Exposure Plan",
			"request": {
				"method": "DELETE",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/exposure/plan/:id",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"exposure",
						"plan",
						":id"
					],
					"variable": [
						{
							"key": "id",
							"value": "PLAN_ID_HERE"
						}
					]
				},
				"description": "Deletes a specific exposure plan."
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "token",
			"value": "YOUR_JWT_TOKEN_HERE"
		},
		{
			"key": "baseUrl",
			"value": "http://localhost:5005/api"
		}
	]
}
