{
	"info": {
		"name": "MY-EMDR Category & Media",
		"description": "APIs for category management and media (images, videos, logic) retrieval.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Categories",
			"item": [
				{
					"name": "List All Categories",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/categories",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"categories"
							]
						}
					},
					"response": []
				},
				{
					"name": "Get Category Media (Grouped)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/categories/:categoryId/media",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"categories",
								":categoryId",
								"media"
							],
							"variable": [
								{
									"key": "categoryId",
									"value": "PASTE_CATEGORY_ID_HERE"
								}
							]
						},
						"description": "Returns images, videos, and audios for a specific category."
					},
					"response": []
				}
			]
		},
		{
			"name": "Media",
			"item": [
				{
					"name": "Upload New Media (Admin Only)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "categoryId",
									"value": "PASTE_CATEGORY_ID_HERE",
									"type": "text"
								},
								{
									"key": "name",
									"value": "Instrumental Background",
									"type": "text"
								},
								{
									"key": "image",
									"type": "file",
									"src": []
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/media",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"media"
							]
						}
					},
					"response": []
				},
				{
					"name": "List All Media (Paginated)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/media?page=1&limit=10&categoryId=&status=active",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"media"
							],
							"query": [
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "limit",
									"value": "10"
								},
								{
									"key": "categoryId",
									"value": ""
								},
								{
									"key": "status",
									"value": "active"
								}
							]
						}
					},
					"response": []
				}
			]
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{accessToken}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:5005",
			"type": "string"
		},
		{
			"key": "accessToken",
			"value": "PASTE_YOUR_TOKEN_HERE",
			"type": "string"
		}
	]
}
