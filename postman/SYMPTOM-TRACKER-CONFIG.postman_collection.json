{
  "info": {
    "name": "SYMPTOM-TRACKER-SYSTEM",
    "_postman_id": "symptom-tracker-system-collection",
    "description": "Full Symptom Tracker flow — Admin config setup + User submission + History + Trend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:5000/api", "type": "string" },
    { "key": "adminToken",   "value": "", "type": "string" },
    { "key": "userToken",    "value": "", "type": "string" },
    { "key": "trackerType",  "value": "anxiety", "type": "string" },
    { "key": "submissionId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "STEP 1 — Admin: Seed Tracker Config",
      "description": "Admin does this once to create the tracker definition in DB.",
      "item": [
        {
          "name": "Create Anxiety Config",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trackerType\": \"anxiety\",\n  \"name\": \"Anxiety\",\n  \"description\": \"A brief check-in on how anxiety has shown up in your body, mind, and daily life over the past week.\",\n  \"items\": [\n    { \"text\": \"My body has felt activated when there was no real reason for it (heart, breath, muscles, gut).\", \"reverse\": false },\n    { \"text\": \"I have noticed a background hum of unease that wouldn't lift.\", \"reverse\": false },\n    { \"text\": \"My mind has jumped ahead to things that could go wrong.\", \"reverse\": false },\n    { \"text\": \"I have changed plans or skipped things because of how I expected to feel.\", \"reverse\": false },\n    { \"text\": \"I have struggled to drop into rest, even when the day was done.\", \"reverse\": false },\n    { \"text\": \"My nervous system has felt steady and at ease.\", \"reverse\": true },\n    { \"text\": \"I have felt braced or guarded without knowing what for.\", \"reverse\": false },\n    { \"text\": \"I have noticed it taking longer to recover from small stresses.\", \"reverse\": false },\n    { \"text\": \"My anxiety has spilled into work, study, or daily tasks.\", \"reverse\": false },\n    { \"text\": \"My anxiety has shaped how I show up with the people around me.\", \"reverse\": false }\n  ],\n  \"options\": [\n    { \"value\": 0, \"label\": \"Never\" },\n    { \"value\": 1, \"label\": \"Rarely\" },\n    { \"value\": 2, \"label\": \"Sometimes\" },\n    { \"value\": 3, \"label\": \"Often\" },\n    { \"value\": 4, \"label\": \"Almost always\" }\n  ],\n  \"bands\": [\n    { \"max\": 9,  \"label\": \"Minimal\",  \"description\": \"Few symptoms of anxiety reported in the past week.\" },\n    { \"max\": 17, \"label\": \"Mild\",     \"description\": \"Some symptoms present but unlikely to be substantially disrupting daily life.\" },\n    { \"max\": 25, \"label\": \"Moderate\", \"description\": \"A meaningful pattern of anxiety symptoms over the past week.\" },\n    { \"max\": 32, \"label\": \"Marked\",   \"description\": \"Substantial anxiety symptoms with likely impact on functioning and wellbeing.\" },\n    { \"max\": 40, \"label\": \"Severe\",   \"description\": \"A high level of anxiety symptoms with significant impact across multiple areas of life.\" }\n  ],\n  \"alerts\": [],\n  \"stemKey\": null,\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/admin/configs",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "admin", "configs"]
            }
          }
        },
        {
          "name": "List All Configs (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/admin/configs",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "admin", "configs"]
            }
          }
        },
        {
          "name": "Update Config",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isActive\": true,\n  \"description\": \"Updated description.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/admin/configs/{{trackerType}}",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "admin", "configs", "{{trackerType}}"]
            }
          }
        },
        {
          "name": "Delete Config",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/admin/configs/{{trackerType}}",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "admin", "configs", "{{trackerType}}"]
            }
          }
        }
      ]
    },
    {
      "name": "STEP 2 — Public: Load Config (App fetches this to render UI)",
      "item": [
        {
          "name": "List All Active Configs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/configs",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "configs"]
            }
          }
        },
        {
          "name": "Get Anxiety Config",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/configs/{{trackerType}}",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "configs", "{{trackerType}}"]
            }
          }
        }
      ]
    },
    {
      "name": "STEP 3 — User: Submit Answers",
      "item": [
        {
          "name": "Submit Tracker (Moderate score example)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data.submissionId) {",
                  "  pm.collectionVariables.set('submissionId', res.data.submissionId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trackerType\": \"anxiety\",\n  \"answers\": [3, 2, 3, 1, 2, 1, 2, 3, 2, 2],\n  \"stemValue\": null\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/submit",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "submit"]
            },
            "description": "answers array must have exactly 10 items (one per question, 0-4 each).\nServer calculates score, applies reverse scoring, determines severity band."
          }
        },
        {
          "name": "Submit Tracker (Minimal score example)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trackerType\": \"anxiety\",\n  \"answers\": [0, 0, 1, 0, 0, 4, 0, 0, 1, 0],\n  \"stemValue\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/submit",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "submit"]
            }
          }
        },
        {
          "name": "Submit Tracker (Severe score example)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trackerType\": \"anxiety\",\n  \"answers\": [4, 4, 4, 4, 4, 0, 4, 4, 4, 4],\n  \"stemValue\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/submit",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "submit"]
            }
          }
        }
      ]
    },
    {
      "name": "STEP 4 — User: View History & Progress",
      "item": [
        {
          "name": "Get History (all trackers)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/history?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "history"],
              "query": [
                { "key": "page",  "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get History (anxiety only)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/history?trackerType=anxiety&page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "history"],
              "query": [
                { "key": "trackerType", "value": "anxiety" },
                { "key": "page",        "value": "1" },
                { "key": "limit",       "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Single Submission Detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/history/{{submissionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "history", "{{submissionId}}"]
            }
          }
        },
        {
          "name": "Get Trend (for chart)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/trend?trackerType=anxiety&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "trend"],
              "query": [
                { "key": "trackerType", "value": "anxiety" },
                { "key": "limit",       "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Latest (all tracker types)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/latest",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "latest"]
            }
          }
        },
        {
          "name": "Get Latest (anxiety only)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/symptom-tracker/latest?trackerType=anxiety",
              "host": ["{{baseUrl}}"],
              "path": ["symptom-tracker", "latest"],
              "query": [{ "key": "trackerType", "value": "anxiety" }]
            }
          }
        }
      ]
    }
  ]
}
